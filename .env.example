# =============================================================================
# Travel Discovery Platform — environment variables (names only; no secrets here)
# Copy to .env.local for development. NEVER commit real values.
# See ProjectDocs/Phase0/05_SECURITY_AND_RLS.md §7.
# =============================================================================

# --- Supabase (public; safe in the browser, protected by RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase service role (SERVER ONLY — never prefix with NEXT_PUBLIC, never
#     import into client code). Used by seed/admin scripts. ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary (editorial destination media delivery, D3) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Only needed if editorial media is uploaded via a signed server script:
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Rate limiting (optional; D6). If unset, the limiter runs as a no-op shim. ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
